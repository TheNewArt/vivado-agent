# Vivado Agent Environment Variables
# Copy to .env and fill in your values

# LLM API Configuration (required for Phase 3 debug)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Optional overrides
# VIVADO_PATH=C:\Xilinx\Vivado\2024.1\bin\vivado
# XSIM_CACHE_DIR=./xsim_cache
# LOG_LEVEL=info